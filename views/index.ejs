<main>
  <h1 class="welcome-title">Welcome to CSE Motors!</h1>

  <!-- Delorean container -->
  <div class="delorean-container">
    <img src="/images/vehicles/delorean.jpg" alt="DMC Delorean" class="delorean-img">
    <div class="delorean-text-overlay">
      <h2>DMC Delorean</h2>
      <p>3 Cup holders</p>
      <p>Superman doors</p>
      <p>Fuzzy dice!</p>
      <a href="#" class="btn-delorean">Own Today</a>
    </div>
  </div>

  <!-- Titles in the same line -->
  <div class="titles-row">
    <h2 class="upgrades-title">Delorean Upgrades</h2>
    <h2 class="reviews-title">DMC Delorean Reviews</h2>
  </div>

  <!-- CONTENT ROW (upgrades left, reviews right) -->
  <div class="content-row">
    <!-- Upgrades: images with light blue background -->
    <div class="upgrades-grid">
      <div class="upgrade-item">
        <div class="upgrade-card">
          <img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor">
        </div>
        <a href="#">Flux Capacitor</a>
      </div>

      <div class="upgrade-item">
        <div class="upgrade-card">
          <img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper Stickers">
        </div>
        <a href="#">Bumper Stickers</a>
      </div>

      <div class="upgrade-item">
        <div class="upgrade-card">
          <img src="/images/upgrades/flame.jpg" alt="Flame Decals">
        </div>
        <a href="#">Flame Decals</a>
      </div>

      <div class="upgrade-item">
        <div class="upgrade-card">
          <img src="/images/upgrades/hub-cap.jpg" alt="Hub Caps">
        </div>
        <a href="#">Hub Caps</a>
      </div>
    </div>

    <!-- Reviews -->
    <div class="reviews-box">
      <ul class="reviews-list">
        <li>"So fast it's almost like traveling in time." (4/5)</li>
        <li>"Coolest ride on the road." (4/5)</li>
        <li>"I'm feeling McFly!" (5/5)</li>
        <li>"The most futuristic ride of our day." (4.5/5)</li>
        <li>"80's livin' and I love it!" (5/5)</li>
      </ul>
    </div>
  </div>
</main>