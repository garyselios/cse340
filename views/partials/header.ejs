<header id="top-header">
  <span class="siteName">
    <a href="/" title="Return to home page">CSE Motors</a>
  </span>
  <div id="tools">
    <% if (loggedin) { %>
      <span class="welcome-message">Welcome, <%= accountData.account_firstname %></span>
      <a href="/account/management" title="Account Management">My Account</a>
      <a href="/account/logout" title="Log out">Logout</a>
    <% } else { %>
      <a href="/account/login" title="Click to log in">My Account</a>
    <% } %>
  </div>
</header>