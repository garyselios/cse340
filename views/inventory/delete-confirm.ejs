<main>
  <h1>Delete Vehicle</h1>
  <%- messages() %>

  <% if (errors) { %>
    <ul class="notice">
      <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <div class="delete-confirm">
    <p>Are you sure you want to delete the following vehicle?</p>
    
    <div class="vehicle-info">
      <img src="<%= vehicle.inv_thumbnail %>" alt="Image of <%= vehicle.inv_make %> <%= vehicle.inv_model %>">
      <h3><%= vehicle.inv_make %> <%= vehicle.inv_model %></h3>
      <p><strong>Year:</strong> <%= vehicle.inv_year %></p>
      <p><strong>Price:</strong> $<%= new Intl.NumberFormat('en-US').format(vehicle.inv_price) %></p>
      <p><strong>Color:</strong> <%= vehicle.inv_color %></p>
    </div>

    <div class="delete-actions">
      <form action="/inv/delete/<%= vehicle.inv_id %>" method="POST">
        <button type="submit" class="btn-delete">Yes, Delete Vehicle</button>
        <a href="/inv/detail/<%= vehicle.inv_id %>" class="btn-cancel">Cancel</a>
      </form>
    </div>
  </div>
</main>