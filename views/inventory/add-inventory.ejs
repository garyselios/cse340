<main>
  <h1>Add New Vehicle</h1>
  <%- messages() %>

  <% if (errors) { %>
    <ul class="notice">
      <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/inv/add-inventory" method="post">
    <div>
      <label for="classification_id">Classification</label>
      <%- classificationList %>
    </div>

    <div>
      <label for="inv_make">Make</label>
      <input type="text" id="inv_make" name="inv_make" value="<%= inv_make %>" required>
    </div>

    <div>
      <label for="inv_model">Model</label>
      <input type="text" id="inv_model" name="inv_model" value="<%= inv_model %>" required>
    </div>

    <div>
      <label for="inv_year">Year</label>
      <input type="text" id="inv_year" name="inv_year" value="<%= inv_year %>" required pattern="\d{4}" title="Enter a 4-digit year (e.g., 2020)">
    </div>

    <div>
      <label for="inv_description">Description</label>
      <textarea id="inv_description" name="inv_description" rows="5" required><%= inv_description %></textarea>
    </div>

    <div>
      <label for="inv_image">Image Path</label>
      <input type="text" id="inv_image" name="inv_image" value="<%= inv_image %>" required>
      <small>Example: /images/vehicles/vehicle-name.jpg</small>
    </div>

    <div>
      <label for="inv_thumbnail">Thumbnail Path</label>
      <input type="text" id="inv_thumbnail" name="inv_thumbnail" value="<%= inv_thumbnail %>" required>
      <small>Example: /images/vehicles/vehicle-name-tn.jpg</small>
    </div>

    <div>
      <label for="inv_price">Price</label>
      <input type="number" id="inv_price" name="inv_price" value="<%= inv_price %>" required min="0" step="1">
    </div>

    <div>
      <label for="inv_miles">Miles</label>
      <input type="number" id="inv_miles" name="inv_miles" value="<%= inv_miles %>" required min="0" step="1">
    </div>

    <div>
      <label for="inv_color">Color</label>
      <input type="text" id="inv_color" name="inv_color" value="<%= inv_color %>" required>
    </div>

    <button type="submit">Add Vehicle</button>
  </form>

  <p><a href="/inv/">Back to Management</a></p>
</main>