<main>
  <h1>Add New Classification</h1>
  <%- messages() %>

  <% if (errors) { %>
    <ul class="notice">
      <% errors.array().forEach(error => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/inv/add-classification" method="post">
    <div>
      <label for="classification_name">Classification Name</label>
      <input type="text" id="classification_name" name="classification_name" 
             value="<%= classification_name %>" 
             required 
             pattern="^[a-zA-Z0-9]+$"
             title="Only letters and numbers allowed, no spaces or special characters.">
      <small>Only letters and numbers allowed. No spaces or special characters.</small>
    </div>
    <button type="submit">Add Classification</button>
  </form>

  <p><a href="/inv/">Back to Management</a></p>
</main>